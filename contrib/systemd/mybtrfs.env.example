# mybtrfs backup parameters for the systemd service.
# Install to /etc/default/mybtrfs and edit. These map 1:1 to the positional
# arguments of `mybtrfs run <source> <snapshot_dir> <basename> <target>`.

# The subvolume to back up.
MYBTRFS_SOURCE=/home

# Directory that holds the source-side read-only snapshots.
MYBTRFS_SNAPSHOT_DIR=/home/.mybtrfs_snapshots

# Base name for snapshots/backups (a timestamp is appended).
MYBTRFS_BASENAME=home

# Target directory on the backup filesystem. Must be an explicit, already-mounted
# path: cron/systemd is non-interactive, so the interactive drive picker is not
# used here. Per-host layout (`<mountpoint>/<hostname>/`) is a good convention.
MYBTRFS_TARGET=/mnt/backup/myhost
